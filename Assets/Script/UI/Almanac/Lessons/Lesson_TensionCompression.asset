  m_Script: {fileID: 11500000, guid: 0345522f1e483c24e82a5f0697649860, type: 3}
  m_Name: Lesson_TensionCompression
  m_EditorClassIdentifier: Assembly-CSharp::LessonSO
  lessonTitle: Tension vs. Compression
  lessonContent: 'In bridge engineering, forces act on materials in two main ways:
    Tension and Compression.


    Tension is a pulling force that stretches a material
    outwards. Think of a tug-of-war rope or the cables on a suspension bridge. Steel
    cables are excellent at handling tension.


    Compression is a pushing force
    that squeezes a material inwards. Think of the heavy pillars holding up a bridge
    from underneath. Concrete and thick wood are great at handling compression.


    A
    successful bridge balances both of these forces perfectly!'
  quizQuestion: What type of force stretches a material apart?
  quizOptions:
  - Squeezing
  - Bending
  - Pulling
  - Pushing
  correctOptionIndex: 2
  expReward: 50
