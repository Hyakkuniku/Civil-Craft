  isTutorialContract: 1
  clientName: Professor Bhan
  jobDescription: Build a safe crossing for the merchant cart using your basic wooden
    beams. Make sure to brace your structure with triangles!
  budget: 10000
  liveLoadWeight: 600
  allowedMaterials:
  - material: {fileID: 11400000, guid: d96454d8483949a4fb084d742f9a0ac8, type: 2}
