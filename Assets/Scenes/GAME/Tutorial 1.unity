  m_Script: {fileID: 11500000, guid: cbdcc7b7825c79c4d8972bd1206907dc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  tutorialSteps:
  - message: Meet Professor Bhan at the build site and interact with the construction
      zone to build your first bridge!
    screenPosition: 0
    showNextButton: 0
    canSkip: 0
    isComplete: 0
    OnStepStart:
      m_PersistentCalls:
        m_Calls: []
  - message: Welcome to Build Mode! Your goal is to connect the red anchor points
      across the ravine so the vehicle can cross safely.
    screenPosition: 3
    showNextButton: 1
    canSkip: 0
    isComplete: 0
    OnStepStart:
      m_PersistentCalls:
        m_Calls: []
  - message: Bottom Left has your Materials Panel. It shows your remaining budget
      and available materials. Tap the 'Wood' icon to equip it
    screenPosition: 3
    showNextButton: 1
    canSkip: 0
    isComplete: 0
    OnStepStart:
      m_PersistentCalls:
        m_Calls: []
  - message: To build, tap and hold on a red anchor point, then drag your finger
      to draw a wooden beam. Don't forget to build triangles for strong support!
    screenPosition: 3
    showNextButton: 1
    canSkip: 0
    isComplete: 0
    OnStepStart:
      m_PersistentCalls:
        m_Calls: []
  - message: When you think your bridge is strong enough, press the 'Simulate' button
      up here to send the vehicle across. Good luck, Engineer!
    screenPosition: 0
    showNextButton: 1
    canSkip: 0
    isComplete: 0
    OnStepStart:
      m_PersistentCalls:
        m_Calls: []
